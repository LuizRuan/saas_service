{
  "info": {
    "name": "MãoCerta API",
    "description": "Marketplace de prestadores de serviço locais — Etapas 1 e 2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3333/api", "type": "string" },
    { "key": "tokenAdmin", "value": "", "type": "string" },
    { "key": "tokenClient", "value": "", "type": "string" },
    { "key": "tokenProvider", "value": "", "type": "string" },
    { "key": "categoryId", "value": "", "type": "string" },
    { "key": "requestId", "value": "", "type": "string" },
    { "key": "quoteId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "providerProfileId", "value": "", "type": "string" },
    { "key": "disputeId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔍 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "🏷️ Categorias",
      "item": [
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Buscar categoria por slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/eletricista"
          }
        }
      ]
    },
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Registrar cliente",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register/client",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana Silva\",\n  \"email\": \"ana@email.com\",\n  \"password\": \"senha123\",\n  \"phone\": \"(11) 99999-0000\",\n  \"city\": \"São Paulo\",\n  \"state\": \"SP\"\n}"
            }
          }
        },
        {
          "name": "Registrar prestador",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register/provider",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Técnico\",\n  \"email\": \"carlos@email.com\",\n  \"password\": \"senha123\",\n  \"phone\": \"(11) 98888-0000\",\n  \"city\": \"São Paulo\",\n  \"state\": \"SP\",\n  \"professionalName\": \"Carlos Técnico Elétrica\",\n  \"document\": \"000.000.000-00\",\n  \"categories\": [\"{{categoryId}}\"],\n  \"cities\": [\"São Paulo\"]\n}"
            }
          }
        },
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenAdmin', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@maocerta.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login — Cliente demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenClient', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@maocerta.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login — Prestador demo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('tokenProvider', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"prestador@maocerta.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "GetMe",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "📋 Solicitações de Serviço",
      "item": [
        {
          "name": "Criar solicitação (cliente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('requestId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/service-requests",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenClient}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"city\": \"São Paulo\",\n  \"neighborhood\": \"Moema\",\n  \"approximateAddress\": \"Av. Ibirapuera, próximo ao metrô\",\n  \"fullAddress\": \"Av. Ibirapuera, 2927, ap 42, Moema, SP\",\n  \"description\": \"Preciso de um eletricista para instalar 3 tomadas e revisar o quadro de energia do apartamento.\",\n  \"urgency\": \"medium\",\n  \"desiredDate\": \"2026-07-15T10:00:00.000Z\"\n}"
            }
          }
        },
        {
          "name": "Minhas solicitações (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-requests/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Pedidos disponíveis (prestador)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-requests/available",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }]
          }
        },
        {
          "name": "Detalhe da solicitação",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/service-requests/{{requestId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Cancelar solicitação",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/service-requests/{{requestId}}/cancel",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "💰 Orçamentos",
      "item": [
        {
          "name": "Enviar orçamento (prestador)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('quoteId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/quotes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenProvider}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceRequestId\": \"{{requestId}}\",\n  \"totalAmount\": 350,\n  \"description\": \"Inclui mão de obra, tomadas e revisão do quadro elétrico.\",\n  \"estimatedTime\": \"4 horas\",\n  \"warrantyDays\": 30\n}"
            }
          }
        },
        {
          "name": "Meus orçamentos (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quotes/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Meus orçamentos (prestador)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quotes/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }]
          }
        },
        {
          "name": "Orçamentos da solicitação (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quotes/request/{{requestId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Aceitar orçamento (cliente) ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('orderId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/quotes/{{quoteId}}/accept",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Rejeitar orçamento (cliente)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/quotes/{{quoteId}}/reject",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "📦 Ordens de Serviço",
      "item": [
        {
          "name": "Minhas ordens (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Minhas ordens (prestador)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }]
          }
        },
        {
          "name": "Detalhe da ordem",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Iniciar serviço — in_progress (prestador)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenProvider}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Finalizar serviço — waiting_approval (prestador)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenProvider}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"waiting_approval\"\n}"
            }
          }
        },
        {
          "name": "Upload fotos antes (prestador)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/photos",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "before", "type": "text" },
                { "key": "photos", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Upload fotos depois (prestador)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/photos",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "after", "type": "text" },
                { "key": "photos", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Assinatura do prestador",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/signatures",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenProvider}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"provider\",\n  \"signature\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\"\n}"
            }
          }
        },
        {
          "name": "Aprovar conclusão (cliente) ⭐",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/approve-completion",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "💳 Pagamentos",
      "item": [
        {
          "name": "Simular depósito 20% (cliente) ⭐",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/{{orderId}}/deposit/simulate",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Simular restante 80% (cliente) ⭐",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/{{orderId}}/remaining/simulate",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Meus pagamentos (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Meus pagamentos (prestador)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenProvider}}" }]
          }
        }
      ]
    },
    {
      "name": "⭐ Avaliações",
      "item": [
        {
          "name": "Avaliar prestador (cliente) ⭐",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/reviews",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenClient}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"rating\": 5,\n  \"comment\": \"Ótimo serviço! Pontual, organizado e deixou tudo limpo.\",\n  \"punctuality\": 5,\n  \"quality\": 5,\n  \"communication\": 5,\n  \"cleanliness\": 5\n}"
            }
          }
        },
        {
          "name": "Reviews do prestador (público)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/provider/PROVIDER_USER_ID"
          }
        },
        {
          "name": "Minhas avaliações (cliente)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reviews/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "⚠️ Disputas",
      "item": [
        {
          "name": "Abrir disputa (cliente)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data._id) {",
                  "  pm.collectionVariables.set('disputeId', json.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/disputes",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenClient}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"reason\": \"Serviço incompleto\",\n  \"description\": \"O prestador não instalou todas as tomadas conforme combinado no orçamento.\"\n}"
            }
          }
        },
        {
          "name": "Minhas disputas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/disputes/my",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        },
        {
          "name": "Detalhe da disputa",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/disputes/{{disputeId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenClient}}" }]
          }
        }
      ]
    },
    {
      "name": "🛠️ Admin",
      "item": [
        {
          "name": "Listar usuários",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Listar prestadores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/providers",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Aprovar prestador",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/providers/{{providerProfileId}}/approve",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Bloquear prestador",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/providers/{{providerProfileId}}/block",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Listar solicitações",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/service-requests",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Listar ordens",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Listar pagamentos",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/payments",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Listar disputas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/disputes",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }]
          }
        },
        {
          "name": "Atualizar status de disputa",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/disputes/{{disputeId}}/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved_client\",\n  \"adminNotes\": \"Após análise, o cliente tem razão. Reembolso aprovado.\"\n}"
            }
          }
        }
      ]
    }
  ]
}
