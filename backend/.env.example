NODE_ENV=development
PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/maocerta?retryWrites=true&w=majority

# JWT
JWT_SECRET=sua-chave-secreta-jwt-troque-em-producao
JWT_EXPIRES_IN=7d

# Admin seed
ADMIN_EMAIL=admin@maocerta.com.br
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Administrador MãoCerta

# Negócio
PLATFORM_COMMISSION_PERCENT=10

# CORS (URL do frontend)
CORS_ORIGIN=http://localhost:5173

# Upload (Cloudinary — configurar na Etapa 3)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pagamento (Asaas / Mercado Pago — configurar na Etapa 5)
PAYMENT_GATEWAY=simulated
ASAAS_API_KEY=
ASAAS_SANDBOX=true
MP_ACCESS_TOKEN=
