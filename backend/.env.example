# ============================================================
# MãoCerta API — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Servidor
PORT=3333
NODE_ENV=development

# ── Banco de dados ───────────────────────────────────────────
# Deixe USE_MEMORY_DB=true para rodar sem banco externo (dev local)
USE_MEMORY_DB=true

# ── Seed de dados demo ────────────────────────────────────────
# Deixe false em produção. true para popular banco com dados de teste
SEED_DEMO_DATA=false

# Para usar MongoDB Atlas, preencha MONGODB_URI e remova USE_MEMORY_DB
MONGODB_URI=

# ── Autenticação ─────────────────────────────────────────────
JWT_SECRET=dev_secret_change_in_production
JWT_EXPIRES_IN=7d

# ── Admin seed (criado automaticamente na inicialização) ─────
ADMIN_EMAIL=admin@maocerta.com
ADMIN_PASSWORD=123456
ADMIN_NAME=Administrador MãoCerta

# ── Upload ───────────────────────────────────────────────────
# local = salva em uploads/ (MVP)
# Futuramente: cloudinary | s3
UPLOAD_PROVIDER=local
UPLOAD_MAX_SIZE_MB=10

# ── Plataforma ───────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
DEPOSIT_PERCENT=20

# ── Frontend (CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
