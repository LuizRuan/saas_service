# ============================================================
# MãoCerta API — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Servidor
PORT=3333
NODE_ENV=development

# ── Banco de dados ───────────────────────────────────────────
# Deixe USE_MEMORY_DB=true para rodar sem banco externo (dev local)
USE_MEMORY_DB=true

# ── Seed de dados demo ────────────────────────────────────────
# Deixe false em produção. true para popular banco com dados de teste
SEED_DEMO_DATA=false

# Para usar MongoDB Atlas, preencha MONGODB_URI e remova USE_MEMORY_DB
MONGODB_URI=

# ── Autenticação ─────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
REFRESH_TOKEN_SECRET=
JWT_EXPIRES_IN=1h

# ── Admin seed (criado automaticamente na inicialização) ─────
ADMIN_EMAIL=admin@maocerta.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrador MãoCerta

# ── Upload ───────────────────────────────────────────────────
# local = salva em uploads/ (MVP)
# Futuramente: cloudinary | s3
UPLOAD_PROVIDER=local
UPLOAD_MAX_SIZE_MB=10

# ── Plataforma ───────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
DEPOSIT_PERCENT=20

# ── Frontend (CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────
# Obtenha em https://resend.com → API Keys
RESEND_API_KEY=
# Domínio verificado no Resend (usar noreply@seudominio.com em produção)
FROM_EMAIL=noreply@maocerta.com
# URL base do frontend (usado nos links de email)
APP_URL=http://localhost:5173
